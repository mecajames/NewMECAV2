VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# API Backend URL
VITE_API_URL=http://localhost:3001

# Google reCAPTCHA v3
# Get your keys from: https://www.google.com/recaptcha/admin
# Use the SITE KEY here (not the secret key)
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key-here

# Stripe
# Get your keys from: https://dashboard.stripe.com/apikeys
# Use the PUBLISHABLE KEY here (not the secret key)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here

# Google Analytics 4 — the WEB STREAM measurement ID (looks like G-XXXXXXXXXX).
# REQUIRED for site analytics to collect data. Vite inlines this at BUILD time,
# so it MUST be present in the environment that builds the production bundle
# (not just on the running server) — rebuild + redeploy after setting it.
# Without it, the gtag script never loads and Google Analytics records nothing.
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
