# NewMECA V2 - Backend Environment Variables for Deployment
# Used by deploy.ps1 to inject into the container deployment
# Copy this file to .env.backend and fill in your values
#
# ALL keys in this file will be injected into the container.
# No need to update deploy.ps1 or deployment.template.json when adding new vars.

# Database
DATABASE_URL=postgresql://postgres:your-password@your-host:5433/postgres

# Supabase
SUPABASE_URL=https://db.mecacaraudio.com
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# CORS / Frontend
CORS_ORIGIN=https://stage.mecacaraudio.com,https://v2-container-service-1.4jtl2jdpv8nts.us-east-1.cs.amazonlightsail.com
FRONTEND_URL=https://stage.mecacaraudio.com

# reCAPTCHA
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-here

# Admin
SUPER_ADMIN_PASSWORD=

# Google Analytics 4
GA4_PROPERTY_ID=your-ga4-property-id
GA4_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# Email (Mailgun HTTP API)
EMAIL_PROVIDER=mailgun
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_API_URL=https://api.mailgun.net
MAILGUN_DOMAIN=mg.mecacaraudio.com
MAILGUN_FROM_EMAIL=noreply@mecacaraudio.com
CONTACT_FORM_EMAIL=mecacaraudio@gmail.com

# Constant Contact
CONSTANT_CONTACT_ACCESS_TOKEN=your-access-token
CONSTANT_CONTACT_API_KEY=your-api-key
CONSTANT_CONTACT_CLIENT_SECRET=your-client-secret
CONSTANT_CONTACT_LIST_ID=your-list-ids
CONSTANT_CONTACT_REFRESH_TOKEN=your-refresh-token

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# USPS
USPS_CONSUMER_KEY=your-usps-consumer-key
USPS_CONSUMER_SECRET=your-usps-consumer-secret
