{
  "serviceName": "v2-container-service-1",
  "containers": {
    "backend": {
      "image": "PLACEHOLDER",
      "command": [],
      "environment": {
        "NODE_ENV": "production",
        "PORT": "3000",
        "NODE_OPTIONS": "--max-old-space-size=512 --experimental-global-webcrypto",
        "EMAIL_PROVIDER": "mailgun"
      },
      "ports": {
        "3000": "HTTP"
      }
    },
    "nginx": {
      "image": "PLACEHOLDER",
      "command": [],
      "environment": {},
      "ports": {
        "80": "HTTP"
      }
    }
  },
  "publicEndpoint": {
    "containerName": "nginx",
    "containerPort": 80,
    "healthCheck": {
      "healthyThreshold": 2,
      "unhealthyThreshold": 5,
      "timeoutSeconds": 10,
      "intervalSeconds": 30,
      "path": "/health",
      "successCodes": "200"
    }
  }
}
